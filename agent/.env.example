# ── Alisha Agent API Keys ──
# Copy this file to .env and fill in your API keys
# Or add them as secrets in your HuggingFace Space settings

# HuggingFace Inference API (required for default provider)
HF_TOKEN=hf_your_token_here

# NVIDIA NIM API (optional - for Llama 3.1 405B, Nemotron, DeepSeek)
NVIDIA_API_KEY=nvapi-your_key_here

# Groq API (optional - for fast Llama 3.3, Mixtral inference)
GROQ_API_KEY=gsk_your_key_here

# Google Gemini API (optional - for Gemini 2.0 Flash, 1.5 Pro)
GOOGLE_API_KEY=AIzaSy_your_key_here

# GitHub Personal Access Token (optional - for repo write operations)
# Read operations on public repos work without this
GITHUB_TOKEN=ghp_your_token_here
